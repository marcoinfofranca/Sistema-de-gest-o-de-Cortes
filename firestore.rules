rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: nome (string), email (string), perfil (string: admin|barbeiro), ativo (bool), criado_em (timestamp)
    //
    // Collection: associados
    // Fields: nome (string), cpf (string), data_nascimento (string), telefone (string), email (string), ativo (bool), criado_em (timestamp)
    //
    // Collection: fornecedores
    // Fields: nome (string), cpf_cnpj (string), endereco (string), telefone (string), whatsapp (string), email (string), banco (string), agencia (string), conta (string), ativo (bool), usuario_id (string), criado_em (timestamp)
    //
    // Collection: configuracoes_valor
    // Fields: valor (number), data_inicio (timestamp), data_fim (timestamp|null), observacao (string), criado_por (string), criado_em (timestamp)
    //
    // Collection: configuracoes_expiracao
    // Fields: dias_validade (number), data_inicio (timestamp), observacao (string), criado_por (string), criado_em (timestamp)
    //
    // Collection: qrcodes
    // Fields: associado_id (string), emitido_em (timestamp), expira_em (timestamp), status (string: ativo|utilizado|expirado|cancelado), criado_por (string)
    //
    // Collection: atendimentos
    // Fields: qrcode_id (string), fornecedor_id (string), associado_id (string), data_hora (timestamp), valor_aplicado (number), status_pagamento (string: pendente|pago), pagamento_id (string|null)
    //
    // Collection: pagamentos
    // Fields: fornecedor_id (string), data_pagamento (timestamp), valor_total (number), forma_pagamento (string), comprovante_url (string|null), criado_por (string), criado_em (timestamp)

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.perfil == 'admin' ||
         (request.auth.token.email == "marcoinfofranca@gmail.com" && request.auth.token.email_verified == true));
    }

    function isBarbeiro() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.perfil == 'barbeiro';
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() || (isOwner(userId) && request.resource.data.perfil == 'barbeiro');
      allow update: if isAdmin() || (isOwner(userId) && request.resource.data.perfil == resource.data.perfil);
    }

    match /associados/{associadoId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /fornecedores/{fornecedorId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /configuracoes_valor/{configId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /configuracoes_expiracao/{configId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /qrcodes/{qrcodeId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      allow update: if isAdmin() || (isBarbeiro() && request.resource.data.status == 'utilizado' && resource.data.status == 'ativo');
    }

    match /atendimentos/{atendimentoId} {
      allow read: if isAuthenticated();
      allow create: if isBarbeiro() || isAdmin();
      allow update: if isAdmin();
    }

    match /pagamentos/{pagamentoId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
